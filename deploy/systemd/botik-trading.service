[Unit]
Description=Botik Trading Service
After=network-online.target
Wants=network-online.target

[Service]
Type=simple
User=botik
WorkingDirectory=/opt/Botik
EnvironmentFile=/opt/Botik/.env
ExecStart=/opt/Botik/.venv/bin/python -m src.botik.main --config /opt/Botik/config.yaml
Restart=always
RestartSec=3
TimeoutStopSec=20

[Install]
WantedBy=multi-user.target
