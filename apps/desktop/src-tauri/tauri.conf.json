{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Botik Foundation",
  "version": "0.0.0",
  "identifier": "com.botik.foundation",
  "build": {
    "beforeDevCommand": "",
    "beforeBuildCommand": "corepack pnpm --dir ../../frontend build",
    "devUrl": "http://127.0.0.1:4173",
    "frontendDist": "../../../frontend/dist"
  },
  "app": {
    "windows": [
      {
        "title": "Botik Foundation",
        "width": 1280,
        "height": 800,
        "decorations": false,
        "resizable": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.ico"]
  }
}
