# Telegram chat ID for commands/notifications
TELEGRAM_CHAT_ID=

# Bybit DEMO API
BYBIT_API_KEY=
BYBIT_API_SECRET_KEY=
# Legacy fallback:
BYBIT_API_SECRET=
BYBIT_RSA_PRIVATE_KEY_PATH=
