# Copy this file to .env and fill values.
# Do not commit .env (it is in .gitignore).

# ── Database ─────────────────────────────────────────────────────────────────
# SQLite (default, leave empty):
#   DB_URL=sqlite:///data/botik.db
# PostgreSQL (optional, for scale):
#   DB_URL=postgresql://botik:password@localhost:5432/botik
DB_URL=

# Telegram bot token (from @BotFather)
TELEGRAM_BOT_TOKEN=

# Telegram chat ID for commands/notifications
TELEGRAM_CHAT_ID=

# Bybit DEMO API
BYBIT_API_KEY=
BYBIT_API_SECRET_KEY=
# Legacy fallback:
BYBIT_API_SECRET=
BYBIT_RSA_PRIVATE_KEY_PATH=
